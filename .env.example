# Synapse Environment Configuration

# OpenAI API Key (for OpenAI provider agents)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: Custom OpenAI-compatible API base URL
# Use for: OpenRouter, Together AI, local LLM proxies, etc.
# OPENAI_BASE_URL=https://api.openai.com

# Anthropic API Key (for Claude provider agents)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional: Custom Anthropic API base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Custom API key references
# You can define additional keys and reference them in agent configurations
# CUSTOM_API_KEY=your-key-here
