# Synapse Environment Configuration

# =============================================================================
# Option 1: OpenRouter (Recommended - access to 100+ models)
# =============================================================================
# Get key from: https://openrouter.ai/settings/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# Option 2: OpenAI (official API)
# =============================================================================
# Get key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com

# =============================================================================
# Option 3: Anthropic (for Claude models)
# =============================================================================
# Get key from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
# Option 4: Local LLMs (Ollama, etc.)
# =============================================================================
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1

# =============================================================================
# Custom API key references (optional)
# Define additional keys and reference them in agent configurations
# =============================================================================
# CUSTOM_API_KEY=your-key-here
